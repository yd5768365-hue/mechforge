# MechForge AI - 环境变量配置模板
# 复制此文件为 .env 并根据需要修改

# ==================== Ollama 配置 ====================
# Ollama 服务地址
OLLAMA_URL=http://ollama:11434

# 默认使用的模型
# 常用模型: qwen2.5:1.5b, qwen2.5:7b, llama3, mistral
OLLAMA_MODEL=qwen2.5:1.5b

# Ollama 端口（仅用于 docker-compose 端口映射）
OLLAMA_PORT=11434

# ==================== Web 服务配置 ====================
# Web 服务端口
WEB_PORT=8080

# Web 服务主机
WEB_HOST=0.0.0.0

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== RAG 配置 ====================
# 是否启用 RAG
MECHFORGE_RAG_ENABLED=true

# 嵌入模型
# 常用模型: all-MiniLM-L6-v2, all-mpnet-base-v2, paraphrase-multilingual-mpnet-base-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==================== 路径配置 ====================
# 知识库路径（容器内）
MECHFORGE_KNOWLEDGE=/app/knowledge

# 工作目录（容器内）
MECHFORGE_WORKDIR=/app/workdir

# 数据目录（容器内）
MECHFORGE_DATA=/app/data

# ==================== Docker 配置 ====================
# Docker 镜像仓库（用于自定义仓库）
# DOCKER_REGISTRY=myregistry.com/

# 镜像标签
IMAGE_TAG=latest

# ==================== API 配置 ====================
# API 密钥（可选，用于认证）
# API_KEY=your-api-key-here

# 最大请求大小（MB）
# MAX_REQUEST_SIZE=100