# MechForge AI - Package Manifest

# Include documentation
include README.md
include LICENSE
include CHANGELOG.md
include FINAL_UPDATE_SUMMARY.md
include GGUF_UNIFIED_UPDATE.md
include OPTIMIZATION_*.md

# Include configuration files
include config.yaml
include pyproject.toml

# Include scripts
recursive-include scripts *.py *.sh *.bat

# Include examples
recursive-include examples *.py *.md

# Include documentation source (but not built)
recursive-include docs *.md *.yml *.txt
prune docs/site

# Include tests
recursive-include tests *.py

# Exclude development files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .git*
global-exclude .DS_Store
prune .git
prune .github
prune build
dist
*.egg-info

# Exclude large binary files (users should download separately)
exclude *.gguf
exclude *.bin
recursive-exclude models *
recursive-exclude knowledge *.pdf
recursive-exclude workdir *
recursive-exclude .cache *
recursive-exclude .logs *
