# MechForge AI - 环境变量配置
# 复制自 .env.example 并根据本地环境调整

# ==================== Ollama 配置 ====================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ==================== Web 服务配置 ====================
WEB_PORT=8080
WEB_HOST=0.0.0.0

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== RAG 配置 ====================
MECHFORGE_RAG_ENABLED=false
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==================== 路径配置 ====================
MECHFORGE_KNOWLEDGE=./knowledge
MECHFORGE_WORKDIR=./workdir
MECHFORGE_DATA=./data