# MechForge AI GUI 环境变量模板
# 复制此文件为 .env 并填入实际值

# ═══════════════════════════════════════════════════════════════
# AI 提供商配置
# ═══════════════════════════════════════════════════════════════

# OpenAI API Key
OPENAI_API_KEY=sk-xxx

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# Ollama 服务地址
OLLAMA_URL=http://localhost:11434

# 默认模型
OLLAMA_MODEL=qwen2.5:3b

# ═══════════════════════════════════════════════════════════════
# RAG 配置
# ═══════════════════════════════════════════════════════════════

# 启用 RAG
MECHFORGE_RAG=false

# 知识库路径
MECHFORGE_KNOWLEDGE_PATH=./knowledge

# ═══════════════════════════════════════════════════════════════
# 应用配置
# ═══════════════════════════════════════════════════════════════

# 日志级别: DEBUG, INFO, WARNING, ERROR
MECHFORGE_LOG_LEVEL=INFO

# UI 主题: dark, light
MECHFORGE_THEME=dark

# 语言: zh-CN, en-US
MECHFORGE_LANGUAGE=zh-CN

# ═══════════════════════════════════════════════════════════════
# 服务器配置
# ═══════════════════════════════════════════════════════════════

# 服务器主机地址（默认: 127.0.0.1）
MECHFORGE_HOST=127.0.0.1

# 服务器端口（默认: 5000）
MECHFORGE_PORT=5000

# CORS 允许的来源，逗号分隔（默认: *）
MECHFORGE_CORS_ORIGINS=*

# 调试模式（默认: false）
MECHFORGE_DEBUG=false

# ═══════════════════════════════════════════════════════════════
# GGUF 配置
# ═══════════════════════════════════════════════════════════════

# GGUF 服务器地址（默认: http://127.0.0.1:11435）
GGUF_SERVER_URL=http://127.0.0.1:11435

# ═══════════════════════════════════════════════════════════════
# 窗口配置
# ═══════════════════════════════════════════════════════════════

# 窗口标题
MECHFORGE_WINDOW_TITLE=MechForge AI v0.5.0

# 窗口宽度（默认: 1200）
MECHFORGE_WINDOW_WIDTH=1200

# 窗口高度（默认: 800）
MECHFORGE_WINDOW_HEIGHT=800

# 最小窗口宽度（默认: 1000）
MECHFORGE_WINDOW_MIN_WIDTH=1000

# 最小窗口高度（默认: 700）
MECHFORGE_WINDOW_MIN_HEIGHT=700

# 配置目录（默认: ~/.mechforge）
MECHFORGE_CONFIG_DIR=