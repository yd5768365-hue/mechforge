# MechForge AI GUI 环境变量模板
# 复制此文件为 .env 并填入实际值

# ═══════════════════════════════════════════════════════════════
# AI 提供商配置
# ═══════════════════════════════════════════════════════════════

# OpenAI API Key
OPENAI_API_KEY=sk-xxx

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# Ollama 服务地址
OLLAMA_URL=http://localhost:11434

# 默认模型
OLLAMA_MODEL=qwen2.5:3b

# ═══════════════════════════════════════════════════════════════
# RAG 配置
# ═══════════════════════════════════════════════════════════════

# 启用 RAG
MECHFORGE_RAG=false

# 知识库路径
MECHFORGE_KNOWLEDGE_PATH=./knowledge

# ═══════════════════════════════════════════════════════════════
# 应用配置
# ═══════════════════════════════════════════════════════════════

# 日志级别: DEBUG, INFO, WARNING, ERROR
MECHFORGE_LOG_LEVEL=INFO

# UI 主题: dark, light
MECHFORGE_THEME=dark

# 语言: zh-CN, en-US
MECHFORGE_LANGUAGE=zh-CN

# ═══════════════════════════════════════════════════════════════
# 服务器配置
# ═══════════════════════════════════════════════════════════════

# 服务器端口
MECHFORGE_PORT=5000

# 调试模式
MECHFORGE_DEBUG=false