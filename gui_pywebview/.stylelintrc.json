{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "selector-class-pattern": null,
    "selector-id-pattern": null,
    "custom-property-pattern": null,
    "keyframes-name-pattern": null,
    "property-no-vendor-prefix": null,
    "value-no-vendor-prefix": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "no-descending-specificity": null,
    "color-function-notation": "legacy",
    "alpha-value-notation": "number",
    "comment-empty-line-before": null,
    "rule-empty-line-before": ["always", {
      "except": ["first-nested"],
      "ignore": ["after-comment"]
    }],
    "declaration-empty-line-before": ["never"],
    "max-nesting-depth": [5, {
      "ignoreAtRules": ["media", "supports", "each", "for"]
    }],
    "selector-max-compound-selectors": [6],
    "selector-max-specificity": ["0,4,2"],
    "unit-disallowed-list": ["px"],
    "declaration-property-unit-allowed-list": {
      "font-size": ["px", "rem", "em"],
      "line-height": ["px", "rem", "em", ""],
      "width": ["px", "%", "rem", "em", "vw", "ch"],
      "height": ["px", "%", "rem", "em", "vh"],
      "max-width": ["px", "%", "rem", "em", "vw", "ch"],
      "max-height": ["px", "%", "rem", "em", "vh"],
      "min-width": ["px", "%", "rem", "em", "vw", "ch"],
      "min-height": ["px", "%", "rem", "em", "vh"],
      "margin": ["px", "%", "rem", "em"],
      "padding": ["px", "%", "rem", "em"],
      "top": ["px", "%", "rem", "em"],
      "right": ["px", "%", "rem", "em"],
      "bottom": ["px", "%", "rem", "em"],
      "left": ["px", "%", "rem", "em"],
      "border-width": ["px"],
      "border-radius": ["px", "%", "rem", "em"],
      "box-shadow": ["px"],
      "text-shadow": ["px"],
      "transform": ["px", "deg"],
      "animation": ["s", "ms"],
      "transition": ["s", "ms"],
      "gap": ["px", "%", "rem", "em"],
      "column-gap": ["px", "%", "rem", "em"],
      "row-gap": ["px", "%", "rem", "em"],
      "outline-width": ["px"],
      "stroke-width": ["px"]
    }
  },
  "ignoreFiles": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "**/*.min.css"
  ]
}
