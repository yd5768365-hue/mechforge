{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["error", "warn", "info"] }],
    "prefer-const": "error",
    "no-var": "error",
    "object-shorthand": "error",
    "prefer-template": "error",
    "template-curly-spacing": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-param-reassign": ["warn", { "props": false }],
    "prefer-arrow-callback": "error",
    "arrow-spacing": "error",
    "no-duplicate-imports": "error",
    "dot-notation": "error",
    "eqeqeq": ["warn", "smart"],
    "no-alert": "warn",
    "no-debugger": "warn",
    "no-else-return": "error",
    "no-floating-decimal": "error",
    "no-lonely-if": "error",
    "no-multi-spaces": "error",
    "no-multiple-empty-lines": ["error", { "max": 2 }],
    "no-nested-ternary": "warn",
    "no-return-assign": "error",
    "no-throw-literal": "error",
    "no-unneeded-ternary": "error",
    "no-useless-return": "error",
    "prefer-promise-reject-errors": "error",
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "require-await": "off",
    "rest-spread-spacing": "error",
    "sort-imports": ["off"],
    "spaced-comment": ["error", "always"],
    "yoda": "error",
    "no-prototype-builtins": "off",
    "no-constant-condition": "off"
  },
  "globals": {
    "Utils": "readonly",
    "EventBus": "readonly",
    "eventBus": "readonly",
    "Events": "readonly",
    "API": "readonly",
    "apiClient": "readonly",
    "Theme": "readonly",
    "ChatUI": "readonly",
    "ChatHandler": "readonly",
    "ChatFeatures": "readonly",
    "KnowledgeUI": "readonly",
    "CAEWorkBench": "readonly",
    "CAEWorkbench": "readonly",
    "ExperienceUI": "readonly",
    "ExpLib": "readonly",
    "pywebview": "readonly",
    "ModuleLoader": "readonly",
    "EventManager": "readonly",
    "PerformanceMonitor": "readonly",
    "Particles": "readonly",
    "Mascot": "readonly",
    "ModeIndicator": "readonly",
    "StatusBarManager": "readonly",
    "Markdown": "readonly",
    "AIService": "readonly",
    "ConfigService": "readonly",
    "aiService": "writable",
    "configService": "writable",
    "AnimationEngine": "readonly",
    "NotificationManager": "readonly",
    "showToast": "readonly",
    "Store": "readonly",
    "CacheManager": "readonly",
    "ErrorHandler": "readonly",
    "ErrorReporter": "readonly",
    "Logger": "readonly",
    "Storage": "readonly",
    "ThemeManager": "readonly",
    "Validator": "readonly",
    "VirtualList": "readonly",
    "SearchIndex": "readonly",
    "I18n": "readonly",
    "ModalManager": "readonly",
    "DOMUtils": "readonly",
    "debounce": "readonly",
    "throttle": "readonly",
    "escapeHtml": "readonly",
    "highlightCode": "readonly",
    "drawMeshPreview": "readonly",
    "AppState": "readonly",
    "PerformanceOptimizer": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "__pycache__/",
    "*.min.js"
  ]
}
